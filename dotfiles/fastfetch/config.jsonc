// Fastfetch: minimal banner (OS / Date)
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": { "type": "none" },
  "display": {
    "separator": "  ",
    "color": { "keys": "blue" }
  },
  "modules": [
    { "type": "os", "key": "OS", "format": "{name} {version}" },
    { "type": "command", "key": "Date", "text": "d=$(date +%-d);case $d in 1|21|31)s=st;;2|22)s=nd;;3|23)s=rd;;*)s=th;;esac;date +\"%A %B $d$s %Y\"" }
  ]
}
