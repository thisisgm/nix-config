# Font
font-family = JetBrains Mono
font-size = 14
font-thicken = true

# Window
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
macos-titlebar-style = tabs
background-opacity = 0.95
background-blur = 20

# Colors
theme = tokyonight

# Cursor & Behavior
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true
clipboard-paste-protection = true

# Shell & Quality of Life
shell-integration = zsh
# Fix backspace/delete/arrows over SSH WITHOUT writing anything on the remote:
# ssh-env only sets TERM=xterm-256color in the session env (no files installed).
# ssh-terminfo (which would write ~/.terminfo on the remote) stays OFF.
shell-integration-features = cursor,title,path,ssh-env,no-ssh-terminfo
confirm-close-surface = false
auto-update = check

# Optional: Launch opencode via keybind instead of every window
keybind = cmd+shift+o=text:opencode\x0D
